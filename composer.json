{
    "name": "ez-php/audit",
    "version": "1.2.0",
    "description": "Audit log module for ez-php — event-driven recording of entity lifecycle changes (CREATE, UPDATE, DELETE) into an audit_logs table with a fluent query API.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "ez-php/contracts": "^1.0",
        "ez-php/events": "^1.0"
    },
    "require-dev": {
        "ez-php/docker": "^1.0",
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "EzPhp\\Audit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "cs": "php-cs-fixer fix",
        "analyse": "phpstan analyse",
        "test": "phpunit",
        "full": "composer analyse && composer cs && composer test"
    }
}
